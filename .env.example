# Copy this file to .env (same folder) and fill in real values there.
# .env is gitignored - it's never committed, so real credentials never end up
# in source control. start-server.ps1 loads it automatically if present.
#
# Without this file (or with SMTP_HOST left blank), the app still works -
# approval emails are just logged to the server console instead of sent.

# --- Gmail example ---
# 1. Enable 2-Step Verification on the Gmail account: https://myaccount.google.com/security
# 2. Generate an App Password: https://myaccount.google.com/apppasswords
#    (regular Gmail account passwords do NOT work here - it must be an App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=your-16-character-app-password
SMTP_FROM=you@gmail.com
